<TransactionsScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(16)
        spacing: dp(12)
        canvas.before:
            Color:
                rgba: app.color_bg
            Rectangle:
                pos: self.pos
                size: self.size

        ScreenHeader:
            title: "Transactions"

        # Transaction list
        ScrollView:
            RecycleView:
                data: [{'txn_id': t.get('id', 0), 'txn_text': "Rs.{:.0f} - {}".format(t.get('amount',0), t.get('merchant') or 'Unknown'), 'txn_detail': "{} | {} | {}".format((t.get('txn_time','') or '')[:5], t.get('category','Other'), t.get('source_app',''))} for t in root.transactions]
                viewclass: 'TxnDetailItem'
                RecycleBoxLayout:
                    orientation: 'vertical'
                    default_size: None, dp(64)
                    default_size_hint: 1, None
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(6)

        Label:
            text: "{} transaction(s)  •  tap Edit to fix amount or category".format(len(root.transactions))
            font_size: sp(13)
            color: app.color_text_muted
            size_hint_y: None
            height: dp(24)


<TxnDetailItem@BoxLayout>:
    orientation: 'horizontal'
    txn_text: ''
    txn_detail: ''
    txn_id: 0
    size_hint_y: None
    height: dp(64)
    padding: dp(10)
    spacing: dp(8)
    canvas.before:
        Color:
            rgba: app.color_surface_alt
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]

    BoxLayout:
        orientation: 'vertical'
        Label:
            text: root.txn_text
            font_size: sp(15)
            color: app.color_text
            halign: 'left'
            valign: 'middle'
            text_size: self.size
        Label:
            text: root.txn_detail
            font_size: sp(12)
            color: app.color_text_muted
            halign: 'left'
            valign: 'middle'
            text_size: self.size

    FlatButton:
        text: "Edit"
        size_hint_x: None
        width: dp(64)
        font_size: sp(13)
        bg: app.color_surface
        on_release: app.root.get_screen('transactions').edit_transaction(root.txn_id)

    FlatButton:
        text: "Delete"
        size_hint_x: None
        width: dp(68)
        font_size: sp(13)
        bg: [0.40, 0.09, 0.24, 1]
        on_release: app.root.get_screen('transactions').delete_transaction(root.txn_id)
