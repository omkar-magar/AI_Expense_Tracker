<SplashScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(40)
        spacing: dp(20)
        canvas.before:
            Color:
                rgba: 0.12, 0.12, 0.18, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Widget:
            size_hint_y: 0.3

        Label:
            text: "AI Expense Tracker"
            font_size: sp(28)
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(50)

        Label:
            text: "Track. Budget. Save."
            font_size: sp(16)
            color: 0.6, 0.6, 0.7, 1
            size_hint_y: None
            height: dp(30)

        Widget:
            size_hint_y: 0.3

        Label:
            text: "Loading..."
            font_size: sp(14)
            color: 0.5, 0.5, 0.6, 1
            size_hint_y: None
            height: dp(30)
