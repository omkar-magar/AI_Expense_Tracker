<SplashScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(40)
        spacing: dp(16)
        canvas.before:
            Color:
                rgba: app.color_bg
            Rectangle:
                pos: self.pos
                size: self.size

        Widget:
            size_hint_y: 0.34

        # Accent monogram tile
        Widget:
            size_hint: None, None
            size: dp(84), dp(84)
            pos_hint: {'center_x': 0.5}
            canvas:
                Color:
                    rgba: app.color_accent
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(22)]
            Label:
                text: "₹"
                bold: True
                font_size: sp(40)
                color: 1, 1, 1, 1
                center: self.parent.center

        Label:
            text: "AI Expense Tracker"
            font_size: sp(27)
            bold: True
            color: app.color_text
            size_hint_y: None
            height: dp(46)

        Label:
            text: "Track. Budget. Save."
            font_size: sp(15)
            color: app.color_text_muted
            size_hint_y: None
            height: dp(28)

        Widget:
            size_hint_y: 0.34

        Label:
            text: "Loading…"
            font_size: sp(13)
            color: app.color_text_muted
            size_hint_y: None
            height: dp(28)
