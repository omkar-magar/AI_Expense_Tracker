<DashboardScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(16)
        spacing: dp(12)
        canvas.before:
            Color:
                rgba: 0.12, 0.12, 0.18, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # Header
        Label:
            text: root.today_date
            font_size: sp(16)
            color: 0.7, 0.7, 0.8, 1
            size_hint_y: None
            height: dp(30)

        # Budget card
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(140)
            padding: dp(16)
            spacing: dp(8)
            canvas.before:
                Color:
                    rgba: 0.18, 0.18, 0.25, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(12)]

            Label:
                text: "Today's Spending"
                font_size: sp(14)
                color: 0.6, 0.6, 0.7, 1
                size_hint_y: None
                height: dp(24)

            Label:
                text: "Rs. {:.0f}".format(root.today_total)
                font_size: sp(36)
                bold: True
                color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(50)

            BoxLayout:
                size_hint_y: None
                height: dp(24)
                Label:
                    text: "Limit: Rs. {:.0f}".format(root.daily_limit)
                    font_size: sp(13)
                    color: 0.5, 0.5, 0.6, 1
                Label:
                    text: "Remaining: Rs. {:.0f}".format(root.remaining)
                    font_size: sp(13)
                    color: root.status_color

        # Status
        Label:
            text: root.status_text
            font_size: sp(16)
            bold: True
            color: root.status_color
            size_hint_y: None
            height: dp(30)

        # AI Summary card
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(70) if root.ai_summary else dp(0)
            opacity: 1 if root.ai_summary else 0
            padding: dp(12)
            spacing: dp(4)
            canvas.before:
                Color:
                    rgba: 0.15, 0.2, 0.28, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]
            Label:
                text: root.ai_summary
                font_size: sp(12)
                color: 0.75, 0.85, 0.95, 1
                halign: 'left'
                valign: 'top'
                text_size: self.size
                size_hint_y: 1

        # AI Insights card
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(60) if root.ai_insights else dp(0)
            opacity: 1 if root.ai_insights else 0
            padding: dp(12)
            spacing: dp(4)
            canvas.before:
                Color:
                    rgba: 0.2, 0.18, 0.25, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]
            Label:
                text: root.ai_insights
                font_size: sp(11)
                color: 0.7, 0.7, 0.85, 1
                halign: 'left'
                valign: 'top'
                text_size: self.size
                size_hint_y: 1

        # Transaction list header
        BoxLayout:
            size_hint_y: None
            height: dp(30)
            Label:
                text: "Today's Transactions"
                font_size: sp(15)
                bold: True
                color: 0.8, 0.8, 0.9, 1
                halign: 'left'
                text_size: self.size

        # Transaction list
        ScrollView:
            size_hint_y: 1
            RecycleView:
                id: txn_list
                data: [{'text': "Rs.{:.0f} - {} [{}]".format(t.get('amount',0), t.get('merchant','Unknown'), t.get('category','Other'))} for t in root.transactions]
                viewclass: 'TxnLabel'
                RecycleBoxLayout:
                    orientation: 'vertical'
                    default_size: None, dp(40)
                    default_size_hint: 1, None
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(4)

        # Simulate button (for desktop testing)
        Button:
            text: "+ Simulate Notification"
            size_hint_y: None
            height: dp(42)
            font_size: sp(14)
            background_color: 0.2, 0.5, 0.3, 1
            color: 1, 1, 1, 1
            on_release: root.open_simulate_popup()

        # Navigation bar
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(8)

            Button:
                text: "Set Limit"
                on_release: root.manager.current = 'limit'
                background_color: 0.3, 0.3, 0.5, 1
                color: 1, 1, 1, 1

            Button:
                text: "All Txns"
                on_release: root.manager.current = 'transactions'
                background_color: 0.3, 0.3, 0.5, 1
                color: 1, 1, 1, 1

            Button:
                text: "Settings"
                on_release: root.manager.current = 'settings'
                background_color: 0.3, 0.3, 0.5, 1
                color: 1, 1, 1, 1


<TxnLabel@Label>:
    text: ''
    font_size: sp(14)
    color: 0.85, 0.85, 0.9, 1
    halign: 'left'
    valign: 'middle'
    text_size: self.size
    size_hint_y: None
    height: dp(40)
    canvas.before:
        Color:
            rgba: 0.2, 0.2, 0.28, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6)]
