<LimitScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(24)
        spacing: dp(20)
        canvas.before:
            Color:
                rgba: 0.12, 0.12, 0.18, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Widget:
            size_hint_y: 0.15

        Label:
            text: "Set Daily Spending Limit"
            font_size: sp(22)
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(40)

        Label:
            text: "Current Limit: Rs." + root.current_limit
            font_size: sp(16)
            color: 0.6, 0.6, 0.7, 1
            size_hint_y: None
            height: dp(30)

        TextInput:
            id: limit_input
            hint_text: "Enter amount (e.g. 500)"
            input_filter: 'float'
            font_size: sp(20)
            multiline: False
            size_hint_y: None
            height: dp(50)
            padding: dp(12)
            background_color: 0.2, 0.2, 0.28, 1
            foreground_color: 1, 1, 1, 1
            hint_text_color: 0.4, 0.4, 0.5, 1

        Button:
            text: "Save Limit"
            font_size: sp(18)
            size_hint_y: None
            height: dp(50)
            background_color: 0.2, 0.6, 0.4, 1
            color: 1, 1, 1, 1
            on_release: root.save_limit(limit_input.text)

        Widget:
            size_hint_y: 0.2

        Button:
            text: "Back to Dashboard"
            font_size: sp(15)
            size_hint_y: None
            height: dp(44)
            background_color: 0.3, 0.3, 0.4, 1
            color: 0.8, 0.8, 0.9, 1
            on_release: root.manager.current = 'dashboard'
