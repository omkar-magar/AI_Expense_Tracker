<LimitScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(16)
        canvas.before:
            Color:
                rgba: app.color_bg
            Rectangle:
                pos: self.pos
                size: self.size

        ScreenHeader:
            title: "Daily Limit"

        Widget:
            size_hint_y: None
            height: dp(8)

        # Limit card
        Card:
            size_hint_y: None
            height: dp(210)
            padding: dp(20)
            spacing: dp(14)

            Label:
                text: "Set your daily spending limit"
                font_size: sp(17)
                bold: True
                color: app.color_text
                halign: 'left'
                valign: 'middle'
                text_size: self.width, None
                size_hint_y: None
                height: dp(28)

            BoxLayout:
                size_hint_y: None
                height: dp(30)
                spacing: dp(8)
                Label:
                    text: "Current: ₹" + root.current_limit
                    font_size: sp(14)
                    color: app.color_text_muted
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                ResetButton:
                    size_hint_x: None
                    width: dp(34)
                    icon_color: app.color_text_muted
                    on_release:
                        root.reset_limit()
                        limit_input.text = ''

            ThemeInput:
                id: limit_input
                hint_text: "Enter amount (e.g. 500)"
                input_filter: 'float'
                font_size: sp(20)

            FlatButton:
                text: "Save Limit"
                bg: app.color_accent
                size_hint_y: None
                height: dp(50)
                font_size: sp(16)
                on_release: root.save_limit(limit_input.text)

        Widget:
