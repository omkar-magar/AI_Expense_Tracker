<SettingsScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(14)
        canvas.before:
            Color:
                rgba: app.color_bg
            Rectangle:
                pos: self.pos
                size: self.size

        ScreenHeader:
            title: "Settings"

        # AI status pill
        Label:
            text: root.status_text
            font_size: sp(13)
            bold: True
            color: app.color_good if 'ACTIVE' in root.status_text else (0.95, 0.68, 0.28, 1)
            size_hint_y: None
            height: dp(26)

        # Gemini AI card
        Card:
            size_hint_y: None
            height: dp(250)
            spacing: dp(12)

            Label:
                text: "Gemini AI"
                font_size: sp(17)
                bold: True
                color: app.color_text
                halign: 'left'
                valign: 'middle'
                text_size: self.width, None
                size_hint_y: None
                height: dp(28)

            BoxLayout:
                size_hint_y: None
                height: dp(44)
                Label:
                    text: "Enable AI features"
                    font_size: sp(14)
                    color: app.color_text_muted
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                FlatButton:
                    text: "ON" if root.ai_enabled else "OFF"
                    size_hint_x: None
                    width: dp(72)
                    height: dp(36)
                    radius: self.height / 2
                    bg: app.color_accent if root.ai_enabled else app.color_surface_alt
                    on_release: root.toggle_ai(not root.ai_enabled)

            SectionLabel:
                text: "API Key: " + root.api_key_display

            ThemeInput:
                id: api_key_input
                hint_text: "Paste your Gemini API key"
                password: True
                font_size: sp(14)
                height: dp(46)

            FlatButton:
                text: "Save API Key"
                bg: app.color_accent
                size_hint_y: None
                height: dp(44)
                on_release: root.save_api_key(api_key_input.text)

        # Automatic capture card
        Card:
            size_hint_y: None
            height: dp(120)
            spacing: dp(10)

            Label:
                text: "Automatic Capture"
                font_size: sp(17)
                bold: True
                color: app.color_text
                halign: 'left'
                valign: 'middle'
                text_size: self.width, None
                size_hint_y: None
                height: dp(28)

            FlatButton:
                text: "Grant Notification Access"
                bg: app.color_surface_alt
                size_hint_y: None
                height: dp(44)
                on_release: root.open_notification_access()

            SectionLabel:
                text: "Lets the app auto-read UPI notifications. SMS is read once allowed."
                height: dp(20)

        Widget:
