<SettingsScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(24)
        spacing: dp(16)
        canvas.before:
            Color:
                rgba: 0.12, 0.12, 0.18, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # Header
        BoxLayout:
            size_hint_y: None
            height: dp(44)
            Button:
                text: "< Back"
                size_hint_x: 0.3
                background_color: 0, 0, 0, 0
                color: 0.4, 0.6, 1, 1
                font_size: sp(15)
                on_release: root.manager.current = 'dashboard'
            Label:
                text: "Settings"
                font_size: sp(20)
                bold: True
                color: 1, 1, 1, 1
            Widget:
                size_hint_x: 0.3

        # AI Status
        Label:
            text: root.status_text
            font_size: sp(14)
            bold: True
            color: (0.2, 0.8, 0.4, 1) if 'ACTIVE' in root.status_text else (0.8, 0.6, 0.2, 1)
            size_hint_y: None
            height: dp(30)

        # Gemini section card
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(220)
            padding: dp(16)
            spacing: dp(12)
            canvas.before:
                Color:
                    rgba: 0.18, 0.18, 0.25, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(12)]

            Label:
                text: "Gemini Flash Pro"
                font_size: sp(16)
                bold: True
                color: 0.9, 0.9, 1, 1
                size_hint_y: None
                height: dp(28)

            # AI toggle
            BoxLayout:
                size_hint_y: None
                height: dp(40)
                Label:
                    text: "Enable AI Features"
                    font_size: sp(14)
                    color: 0.7, 0.7, 0.8, 1
                    halign: 'left'
                    text_size: self.size
                    valign: 'center'
                CheckBox:
                    id: ai_toggle
                    active: root.ai_enabled
                    size_hint_x: 0.2
                    on_active: root.toggle_ai(self.active)

            # API key display
            Label:
                text: "API Key: " + root.api_key_display
                font_size: sp(13)
                color: 0.5, 0.5, 0.6, 1
                size_hint_y: None
                height: dp(24)

            # API key input
            TextInput:
                id: api_key_input
                hint_text: "Paste your Gemini API key"
                font_size: sp(14)
                multiline: False
                password: True
                size_hint_y: None
                height: dp(44)
                padding: dp(10)
                background_color: 0.15, 0.15, 0.2, 1
                foreground_color: 1, 1, 1, 1
                hint_text_color: 0.4, 0.4, 0.5, 1

            Button:
                text: "Save API Key"
                font_size: sp(14)
                size_hint_y: None
                height: dp(40)
                background_color: 0.2, 0.5, 0.7, 1
                color: 1, 1, 1, 1
                on_release: root.save_api_key(api_key_input.text)

        # Info
        Label:
            text: "AI powers: smart categorization,\ndaily spending summary, spending insights."
            font_size: sp(13)
            color: 0.4, 0.4, 0.5, 1
            halign: 'center'
            size_hint_y: None
            height: dp(40)

        Label:
            text: "Without AI, the app uses rule-based\ncategorization — no API key needed."
            font_size: sp(12)
            color: 0.35, 0.35, 0.45, 1
            halign: 'center'
            size_hint_y: None
            height: dp(40)

        Widget:
